# ── Copy this file to ".env" and fill in your values ──────────

# Port the server listens on (Render/Railway set this automatically)
PORT=8000

# The public base URL of THIS backend (used to build verify/reset links).
# Locally: http://localhost:8000   In production: https://api.yourdomain.com
PUBLIC_URL=http://localhost:8000

# Comma-separated list of front-end origins allowed to call the API.
# Use * while testing; lock it down in production, e.g. https://app.yourdomain.com
CORS_ORIGIN=*

# Secret used to sign login tokens — set a long random string in production.
JWT_SECRET=replace-with-a-long-random-string

# Where the SQLite file lives (optional). On Render/Railway, point this at a
# mounted volume so accounts survive restarts, e.g. /data/data.json
# DB_PATH=/data/data.json

# ── Email (optional) ──────────────────────────────────────────
# If you leave SMTP blank, the server runs fine and just prints email
# links to the console so you can test. To send real email, fill these
# in (works with Gmail, Mailgun, SendGrid SMTP, Amazon SES, Postmark…).
# MAIL_FROM=TradelineIQ <welcome@yourdomain.com>
# SMTP_HOST=smtp.yourprovider.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-smtp-username
# SMTP_PASS=your-smtp-password
